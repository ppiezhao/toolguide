<!--pages/algorithm/list/list.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      placeholder="搜索算法名称..."
      value="{{searchText}}"
      bindinput="onSearchInput"
      confirm-type="search"
    />
    <text wx:if="{{searchText !== ''}}" class="search-clear" bindtap="onClearSearch">✕</text>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="tab-item {{currentCategory === item.id ? 'active' : ''}}"
      data-category="{{item.id}}"
      bindtap="onSwitchCategory"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-name">{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 难度筛选 -->
  <view class="filter-row">
    <text
      wx:for="{{difficultyFilters}}"
      wx:key="value"
      class="filter-btn {{currentDifficulty === item.value ? 'active filter-'+item.value : ''}}"
      data-difficulty="{{item.value}}"
      bindtap="onSwitchDifficulty"
    >{{item.label}}</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <!-- 错误 -->
  <view wx:elif="{{error}}" class="error-state">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="onRetry">重试</view>
  </view>

  <!-- 算法列表 -->
  <view wx:else class="algo-list">
    <block wx:if="{{filteredAlgorithms.length > 0}}">
      <problem-card
        wx:for="{{filteredAlgorithms}}"
        wx:key="id"
        index="{{index}}"
        id="{{item.meta.id}}"
        name="{{item.meta.name}}"
        difficulty="{{item.meta.difficulty}}"
        timeComplexity="{{item.complexityStr}}"
        spaceComplexity="{{item.meta.spaceComplexity}}"
        stable="{{item.meta.stable}}"
        tags="{{item.meta.tags}}"
        category="{{item.meta.category}}"
        bind:tap="onTapCard"
      />
    </block>

    <view wx:else class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无匹配的算法</text>
      <text class="empty-hint">试试其他分类或难度</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view style="height: 40rpx;"></view>
</view>
