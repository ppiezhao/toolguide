/* pages/algorithm/playground/playground.wxss */
.container {
  padding: 16rpx 24rpx;
  min-height: 100vh;
  background: #F7F7F7;
  box-sizing: border-box;
}

.state-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.state-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.state-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.retry-btn {
  color: #07C160;
  font-size: 28rpx;
  padding: 12rpx 48rpx;
  border: 2rpx solid #07C160;
  border-radius: 32rpx;
}

.canvas-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #E8E8E8;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07C160, #2E8B57);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #07C160;
  font-weight: 600;
  min-width: 64rpx;
  text-align: right;
}

.algo-canvas {
  display: block;
}

.step-desc {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.step-label {
  font-size: 22rpx;
  color: #07C160;
  font-weight: 600;
  margin-right: 16rpx;
}

.step-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

variable-panel {
  display: block;
  margin: 16rpx 0;
}

code-panel {
  display: block;
  margin: 16rpx 0;
}

.desc-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin: 16rpx 0;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.desc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
}

.desc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.desc-arrow {
  font-size: 20rpx;
  color: #999;
  transition: transform 0.3s;
}

.desc-arrow.expanded {
  transform: rotate(180deg);
}

.desc-body {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.desc-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.desc-difficulty {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.difficulty-easy { background: #E8F5E9; color: #07C160; }
.difficulty-medium { background: #FFF8E1; color: #F9A825; }
.difficulty-hard { background: #FFEBEE; color: #E64340; }

.desc-complexity {
  font-size: 22rpx;
  color: #666;
}

.desc-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-line;
}
