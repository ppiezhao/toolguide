/* pages/calendar/calendar.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 20px;
}

/* 头部 */
.header {
  background-color: #FFFFFF;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.header-left {
  display: flex;
  align-items: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #07C160;
}

.header-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.header-right {
  display: flex;
  align-items: center;
}

.screenshot-btn {
  padding: 12rpx 24rpx;
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 26rpx;
  margin: 0;
  line-height: 1;
}

.screenshot-btn::after {
  border: none;
}

.screenshot-btn:active {
  opacity: 0.8;
}

/* 日历区域 */
.calendar-container {
  background-color: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.calendar-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.calendar-nav {
  display: flex;
  gap: 20rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #F7F7F7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  line-height: 1;
}

.nav-btn::after {
  border: none;
}

.nav-btn:active {
  background-color: #E5E5E5;
}

.calendar-week {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.week-item {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  width: 13%;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
  position: relative;
  cursor: pointer;
}

.calendar-day.today {
  background-color: #07C160;
  color: #FFFFFF;
}

.calendar-day.has-check-in::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  width: 8rpx;
  height: 8rpx;
  background-color: #FFB800;
  border-radius: 50%;
}

.calendar-day.selected {
  border: 3rpx solid #07C160;
}

/* 日历内容区域 */
.calendar-content {
  background-color: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
}

.calendar-content:empty {
  display: none;
}

.content-date {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.content-empty {
  color: #999;
  font-size: 28rpx;
  text-align: center;
  padding: 60rpx 0;
}

.content-item {
  margin-bottom: 20rpx;
}

.content-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.content-text {
  padding: 20rpx;
  border: 2rpx dashed #E5E5E5;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  min-height: 80rpx;
  word-break: break-all;
}

.content-text.red {
  color: #E64340;
}

.edit-btn {
  margin-top: auto;
  padding: 20rpx 40rpx;
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin: 20rpx 0 0 0;
  line-height: 1;
  width: 100%;
  text-align: center;
  border: none;
}

.edit-btn::after {
  border: none;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  width: 80%;
  max-width: 500rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.modal-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.modal-textarea.red {
  color: #E64340;
}

.modal-textarea::placeholder {
  color: #999;
}

.modal-textarea:focus {
  border-color: #07C160;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.modal-button {
  flex: 1;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
  line-height: 1;
  margin: 0;
}

.modal-button::after {
  border: none;
}

.modal-button.primary {
  background-color: #07C160;
  color: #FFFFFF;
}

.modal-button.cancel {
  background-color: #F7F7F7;
  color: #666;
}

/* 颜色选择 */
.color-options {
  display: flex;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.color-option {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.color-option.selected {
  border-color: #333;
  transform: scale(1.1);
}

.color-option.black {
  background-color: #333;
}

.color-option.black.selected {
  border-color: #333;
}

.color-option.red {
  background-color: #E64340;
}

.color-option.red.selected {
  border-color: #E64340;
}
