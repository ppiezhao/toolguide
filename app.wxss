/* app.wxss */
page {
  background-color: #F7F7F7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.container {
  min-height: 100vh;
  padding-bottom: 60px;
}

/* 轮播图样式 */
.banner-container {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 360rpx;
}

.banner-slide {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease-in-out;
}

.banner-slide image {
  width: 100%;
  height: 100%;
  display: block;
}

.banner-pagination {
  position: absolute;
  bottom: 20rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  z-index: 10;
}

.banner-pagination .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.5);
  margin: 0 8rpx;
}

.banner-pagination .dot.active {
  background-color: #FFFFFF;
}

/* 分类标签样式 */
.category-tabs {
  display: flex;
  overflow-x: auto;
  white-space: nowrap;
  padding: 20rpx 0;
  -webkit-overflow-scrolling: touch;
}

.category-tabs::-webkit-scrollbar {
  display: none;
}

.category-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin: 0 12rpx;
  border-radius: 32rpx;
  background-color: #FFFFFF;
  color: #333333;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.category-tab.active {
  background-color: #07C160;
  color: #FFFFFF;
}

/* 小程序卡片样式 */
.app-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.app-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.app-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin: 0 auto 16rpx;
}

.app-icon image {
  width: 100%;
  height: 100%;
  display: block;
}

.app-info {
  text-align: center;
}

.app-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.app-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.app-rating {
  margin-top: 16rpx;
  display: flex;
  justify-content: center;
}

.app-rating .star {
  color: #FFB800;
  font-size: 24rpx;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.loading .spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #07C160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}
